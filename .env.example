# Required for live Whisper, embeddings, GPT-4o analysis, and grounded chat.
OPENAI_API_KEY=

# Optional model overrides.
OPENAI_ANALYSIS_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional locally. Required for BullMQ production queueing.
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=1

# Use a persistent mounted directory in production.
MEDIA_DATA_DIR=.data
