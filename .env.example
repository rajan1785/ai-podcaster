# Live AI provider. Set EITHER Groq (free, no card) OR OpenAI.
# Groq is preferred when present: real Whisper transcription + LLM analysis.
GROQ_API_KEY=

# Optional Groq model overrides.
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3
GROQ_ANALYSIS_MODEL=llama-3.3-70b-versatile
GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Alternative provider: OpenAI (used only if GROQ_API_KEY is unset).
OPENAI_API_KEY=
OPENAI_ANALYSIS_MODEL=gpt-4o
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional locally. Required for BullMQ production queueing.
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=1

# Use a persistent mounted directory in production.
MEDIA_DATA_DIR=.data
